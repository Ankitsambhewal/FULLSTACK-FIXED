<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen font-sans">

<!-- NAVBAR -->
<div class="bg-white border-b px-10 py-4 flex justify-between items-center shadow-sm sticky top-0 z-50">
    <h1 class="text-2xl font-bold text-gray-800">Admin Panel</h1>
    <div class="flex items-center gap-4">
        <span class="text-gray-600">Welcome, <strong><%= user ? user.name : "Admin" %></strong></span>
        <a href="/products" class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg text-sm">View Menu</a>
        <a href="/logout" onclick="event.preventDefault(); fetch('/logout',{method:'POST'}).then(()=>window.location.href='/login')"
           class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg text-sm">Logout</a>
    </div>
</div>

<div class="max-w-7xl mx-auto px-6 py-8">

    <!-- STATS -->
    <div class="grid md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white p-6 rounded-2xl shadow border-l-4 border-blue-500">
            <p class="text-gray-500 text-sm">Total Orders</p>
            <p class="text-3xl font-bold mt-1"><%= orders.length %></p>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow border-l-4 border-green-500">
            <p class="text-gray-500 text-sm">Total Products</p>
            <p class="text-3xl font-bold mt-1"><%= products.length %></p>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow border-l-4 border-orange-500">
            <p class="text-gray-500 text-sm">Total Revenue</p>
            <p class="text-3xl font-bold mt-1">₹ <%= orders.reduce((s,o)=>s+(o.totalAmount||0),0) %></p>
        </div>
    </div>

    <!-- TABS -->
    <div class="flex gap-3 mb-8">
        <button onclick="switchTab('orders',event)" class="tab-btn active-tab px-6 py-2.5 rounded-xl font-semibold">
            📦 Orders (<%= orders.length %>)
        </button>
        <button onclick="switchTab('products',event)" class="tab-btn bg-white px-6 py-2.5 rounded-xl font-semibold shadow">
            🍔 Products (<%= products.length %>)
        </button>
    </div>

    <!-- ===== ORDERS TAB ===== -->
    <div id="orders-section" class="tab-content">
        <% if (orders.length === 0) { %>
            <div class="bg-white rounded-2xl p-10 text-center shadow">
                <p class="text-gray-400 text-lg">Koi order nahi abhi tak.</p>
            </div>
        <% } %>

        <% orders.forEach(order => { %>
        <div class="bg-white rounded-2xl p-6 mb-6 shadow border border-gray-100">
            <div class="flex justify-between items-start border-b pb-4 mb-4 flex-wrap gap-3">
                <div>
                    <h3 class="text-lg font-bold"><%= order.user?.name || order.userName || "User" %></h3>
                    <p class="text-gray-500 text-sm"><%= order.user?.email || order.userEmail || "" %></p>
                    <p class="text-xs text-gray-400 mt-1"><%= new Date(order.createdAt).toLocaleString() %></p>
                    <% if (order.pickupTime) { %>
                        <p class="text-xs text-orange-500 font-semibold mt-1">⏰ Pickup: <%= order.pickupTime %></p>
                    <% } %>
                </div>
                <div class="text-right">
                    <span class="px-3 py-1 rounded-full text-xs font-bold
                        <%= order.status==='Pending'   ? 'bg-gray-200 text-gray-700'    :
                            order.status==='Preparing' ? 'bg-yellow-100 text-yellow-700' :
                            order.status==='Delivered' ? 'bg-green-100 text-green-700'  :
                            'bg-red-100 text-red-700' %>">
                        <%= order.status %>
                    </span>
                    <p class="text-2xl font-bold mt-2">₹ <%= order.totalAmount %></p>
                </div>
            </div>

            <div class="space-y-2 mb-4">
                <% order.items.forEach(item => { %>
                <div class="flex justify-between bg-gray-50 px-4 py-3 rounded-xl">
                    <div>
                        <p class="font-medium"><%= item.name %></p>
                        <p class="text-sm text-gray-500">₹ <%= item.price %> × <%= item.quantity %></p>
                    </div>
                    <p class="font-bold">₹ <%= item.price * item.quantity %></p>
                </div>
                <% }) %>
            </div>

            <div class="flex flex-wrap gap-2">
                <button onclick="updateStatus('<%= order._id %>','Pending')"   class="status-btn bg-gray-600">Pending</button>
                <button onclick="updateStatus('<%= order._id %>','Preparing')" class="status-btn bg-yellow-500">Preparing</button>
                <button onclick="updateStatus('<%= order._id %>','Delivered')" class="status-btn bg-green-600">Delivered</button>
                <button onclick="updateStatus('<%= order._id %>','Cancelled')" class="status-btn bg-red-500">Cancelled</button>
            </div>
        </div>
        <% }) %>
    </div>

    <!-- ===== PRODUCTS TAB ===== -->
    <div id="products-section" class="tab-content hidden">

        <!-- ADD PRODUCT FORM -->
        <div class="bg-white p-6 rounded-2xl shadow mb-8">
            <h2 class="text-lg font-bold mb-5">➕ Add New Product</h2>

            <form action="/admin/add-product" method="POST">
                <div class="grid md:grid-cols-2 gap-4 mb-4">

                    <div>
                        <label class="block text-sm font-semibold text-gray-600 mb-1">Product Name *</label>
                        <input type="text" name="name" placeholder="e.g. Chicken Burger" required class="input-field w-full">
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-600 mb-1">Price (₹) *</label>
                        <input type="number" name="price" placeholder="e.g. 250" required min="1" class="input-field w-full">
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-600 mb-1">Category *</label>
                        <select name="category" required class="input-field w-full">
                            <option value="">-- Select Category --</option>
                            <option value="fast food">🍔 Fast Food</option>
                            <option value="desserts">🍰 Desserts</option>
                            <option value="drinks">🥤 Drinks</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-600 mb-1">Description</label>
                        <input type="text" name="description" placeholder="Short description..." class="input-field w-full">
                    </div>

                    <div class="md:col-span-2">
                        <label class="block text-sm font-semibold text-gray-600 mb-1">Image URL * <span class="text-gray-400 font-normal">(Google se image copy karke paste karo)</span></label>
                        <input type="text" name="imageUrl" id="imageUrl" placeholder="https://images.unsplash.com/..." 
                               oninput="previewImage(this.value)" class="input-field w-full">
                    </div>

                </div>

                <!-- Image Preview -->
                <div id="previewBox" class="hidden mb-4">
                    <p class="text-sm text-gray-500 mb-2">Preview:</p>
                    <img id="previewImg" src="" class="w-28 h-28 object-cover rounded-xl border border-gray-200">
                </div>

                <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-xl font-bold text-base transition">
                    ✅ Add Product
                </button>
            </form>
        </div>

        <!-- PRODUCTS LIST -->
        <h2 class="text-lg font-bold mb-4 text-gray-800">All Products (<%= products.length %>)</h2>

        <% if (products.length === 0) { %>
            <div class="bg-white rounded-2xl p-10 text-center shadow">
                <p class="text-gray-400">Koi product nahi. Upar se add karein!</p>
            </div>
        <% } %>

        <div class="grid md:grid-cols-2 gap-4">
        <% products.forEach(product => { %>
        <div class="bg-white p-4 rounded-2xl shadow flex gap-4 items-center border border-gray-100" id="product-<%= product._id %>">
            <img src="<%= product.image %>"
                 onerror="this.src='https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=200'"
                 class="w-20 h-20 object-cover rounded-xl flex-shrink-0">

            <div class="flex-1 min-w-0">
                <p class="font-bold text-gray-800 truncate"><%= product.name %></p>
                <p class="text-green-600 font-semibold">₹ <%= product.price %></p>
                <p class="text-sm text-gray-400 capitalize"><%= product.category %></p>
            </div>

            <div class="flex flex-col gap-2 flex-shrink-0">
                <span class="status-badge px-3 py-1 rounded-full text-xs font-bold text-center
                    <%= product.isAvailable ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                    <%= product.isAvailable ? "✅ Available" : "❌ Out of Stock" %>
                </span>
                <button onclick="toggleProduct('<%= product._id %>',this)"
                    class="px-3 py-1.5 rounded-xl text-white text-xs font-semibold transition
                    <%= product.isAvailable ? 'bg-green-600 hover:bg-green-700' : 'bg-gray-500 hover:bg-gray-600' %>">
                    Toggle
                </button>
                <button onclick="deleteProduct('<%= product._id %>')"
                    class="px-3 py-1.5 rounded-xl text-white text-xs font-semibold bg-red-500 hover:bg-red-600 transition">
                    🗑️ Delete
                </button>
            </div>
        </div>
        <% }) %>
        </div>

    </div>
</div>

<!-- TOAST -->
<div id="toast" class="fixed bottom-6 right-6 bg-gray-900 text-white px-5 py-3 rounded-xl shadow-xl hidden z-50 text-sm font-medium"></div>

<style>
.active-tab  { background: #111827; color: white; }
.status-btn  { padding: 8px 16px; border-radius: 10px; color: white; font-size: 13px; font-weight: 600; cursor: pointer; transition: opacity 0.2s; }
.status-btn:hover { opacity: 0.85; }
.input-field { border: 1px solid #e5e7eb; padding: 11px 14px; border-radius: 10px; outline: none; font-size: 14px; transition: border 0.2s; }
.input-field:focus { border-color: #2563eb; box-shadow: 0 0 0 2px rgba(37,99,235,0.15); }
</style>

<script>
// Tab Switch
function switchTab(tab, event) {
    document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
    document.getElementById(tab + '-section').classList.remove('hidden');
    document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.classList.remove('active-tab');
        btn.classList.add('bg-white');
    });
    event.target.classList.add('active-tab');
    event.target.classList.remove('bg-white');
}

// Image Preview
function previewImage(url) {
    if (url.trim() !== '') {
        document.getElementById('previewImg').src = url;
        document.getElementById('previewBox').classList.remove('hidden');
    } else {
        document.getElementById('previewBox').classList.add('hidden');
    }
}

// Update Order Status
async function updateStatus(id, status) {
    const res = await fetch('/admin/update-order', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ orderId: id, status })
    });
    if (res.ok) { showToast('Order updated: ' + status); setTimeout(() => location.reload(), 800); }
}

// Toggle Product
async function toggleProduct(id, btn) {
    const res  = await fetch(`/admin/toggle-product/${id}`, { method: 'POST' });
    const data = await res.json();
    if (data.success) {
        const card   = btn.parentElement;
        const badge  = card.querySelector('.status-badge');
        if (data.isAvailable) {
            badge.innerText = '✅ Available';
            badge.className = 'status-badge px-3 py-1 rounded-full text-xs font-bold text-center bg-green-100 text-green-700';
            btn.className   = 'px-3 py-1.5 rounded-xl text-white text-xs font-semibold transition bg-green-600 hover:bg-green-700';
        } else {
            badge.innerText = '❌ Out of Stock';
            badge.className = 'status-badge px-3 py-1 rounded-full text-xs font-bold text-center bg-red-100 text-red-700';
            btn.className   = 'px-3 py-1.5 rounded-xl text-white text-xs font-semibold transition bg-gray-500 hover:bg-gray-600';
        }
        showToast(data.isAvailable ? 'Available set!' : 'Out of Stock set!');
    }
}

// Delete Product
async function deleteProduct(id) {
    if (!confirm('Product delete karna chahte ho?')) return;
    const res  = await fetch(`/admin/delete-product/${id}`, { method: 'POST' });
    const data = await res.json();
    if (data.success) {
        document.getElementById('product-' + id).remove();
        showToast('Product deleted!');
    }
}

// Toast
function showToast(msg) {
    const t = document.getElementById('toast');
    t.innerText = msg;
    t.classList.remove('hidden');
    setTimeout(() => t.classList.add('hidden'), 2500);
}
</script>

</body>
</html>
