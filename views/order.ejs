<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Orders</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root { --primary: #ff6b1d; --secondary: #2d3436; --accent: #00b894; --bg: #f0f2f5; }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Poppins', sans-serif; background: var(--bg); color: var(--secondary); }
        .page-header {
            background: linear-gradient(135deg, var(--secondary), #000);
            color: white; padding: 40px 20px; text-align: center;
            border-bottom-left-radius: 40px; border-bottom-right-radius: 40px;
        }
        .page-header h1 { font-size: 2rem; font-weight: 700; }
        .page-header p  { opacity: 0.7; margin-top: 6px; font-size: 14px; }
        .orders-wrapper { max-width: 800px; margin: 30px auto; padding: 0 20px 60px; }
        .empty-orders { background: white; border-radius: 20px; padding: 60px 20px; text-align: center; box-shadow: 0 5px 20px rgba(0,0,0,0.06); }
        .empty-orders i  { font-size: 4rem; color: #ddd; margin-bottom: 20px; }
        .empty-orders h3 { color: #888; font-size: 1.3rem; margin-bottom: 10px; }
        .empty-orders a  { display: inline-block; margin-top: 20px; background: var(--primary); color: white; padding: 12px 30px; border-radius: 12px; text-decoration: none; font-weight: 600; }
        .order-card { background: white; border-radius: 20px; padding: 24px; margin-bottom: 20px; box-shadow: 0 5px 20px rgba(0,0,0,0.07); border: 1px solid #eee; }
        .order-header { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 1px dashed #eee; padding-bottom: 14px; margin-bottom: 14px; flex-wrap: wrap; gap: 10px; }
        .order-id     { font-size: 12px; color: #aaa; margin-bottom: 4px; }
        .order-date   { font-size: 13px; color: #888; margin-top: 4px; }
        .order-pickup { font-size: 13px; color: var(--primary); font-weight: 600; margin-top: 4px; }
        .status-badge { padding: 6px 16px; border-radius: 50px; font-size: 12px; font-weight: 700; white-space: nowrap; }
        .status-Pending   { background: #f0f0f0; color: #666; }
        .status-Preparing { background: #fff3cd; color: #856404; }
        .status-Delivered { background: #d1fae5; color: #065f46; }
        .status-Cancelled { background: #fee2e2; color: #991b1b; }
        .order-item { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #f5f5f5; font-size: 14px; }
        .order-item:last-child { border-bottom: none; }
        .item-name  { color: var(--secondary); font-weight: 500; }
        .item-qty   { color: #888; font-size: 13px; margin-top: 2px; }
        .item-price { font-weight: 700; color: var(--accent); }
        .order-total { display: flex; justify-content: space-between; margin-top: 14px; padding-top: 14px; border-top: 2px dashed #eee; font-weight: 700; font-size: 1.1rem; }
        .menu-link { display: inline-block; margin-top: 16px; background: var(--primary); color: white; padding: 10px 24px; border-radius: 12px; text-decoration: none; font-weight: 600; font-size: 14px; transition: 0.3s; }
        .menu-link:hover { background: #e55a0f; }
    </style>
</head>
<body>

<%- include("partials/navbar", { user: user }) %>

<div class="page-header">
    <h1>📦 My Orders</h1>
    <p>View your order status here</p>
</div>

<div class="orders-wrapper">
    <% if (!orders || orders.length === 0) { %>
        <div class="empty-orders">
            <i class="fas fa-box-open"></i>
            <h3>No orders yet!</h3>
            <a href="/products">Browse Menu</a>
        </div>
    <% } else { %>
        <% orders.forEach(order => { %>
        <div class="order-card">
            <div class="order-header">
                <div>
                    <p class="order-id">Order ID: #<%= order._id.toString().slice(-8).toUpperCase() %></p>
                    <p class="order-date"><i class="fas fa-calendar-alt"></i>
                        <%= new Date(order.createdAt).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short' }) %>
                    </p>
                    <% if (order.pickupTime) { %>
                        <p class="order-pickup"><i class="fas fa-clock"></i> Pickup: <%= order.pickupTime %></p>
                    <% } %>
                </div>
                <span class="status-badge status-<%= order.status %>">
                    <%= order.status === 'Pending'   ? '⏳ Pending'   :
                        order.status === 'Preparing' ? '👨‍🍳 Preparing' :
                        order.status === 'Delivered' ? '✅ Delivered'  : '❌ Cancelled' %>
                </span>
            </div>

            <% order.items.forEach(item => { %>
            <div class="order-item">
                <div>
                    <p class="item-name"><%= item.name %></p>
                    <p class="item-qty">Qty: <%= item.quantity %> × ₹<%= item.price %></p>
                </div>
                <span class="item-price">₹<%= item.price * item.quantity %></span>
            </div>
            <% }) %>

            <div class="order-total">
                <span>Total Amount</span>
                <span>₹<%= order.totalAmount %></span>
            </div>
        </div>
        <% }) %>

        <a href="/products" class="menu-link"><i class="fas fa-utensils"></i> Order More</a>
    <% } %>
</div>

<%- include("partials/footer") %>
</body>
</html>
