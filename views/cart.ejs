<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Cart 🛒</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root { --primary: #ff6b1d; --secondary: #2d3436; --accent: #00b894; --bg: #f0f2f5; }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Poppins', sans-serif; background: var(--bg); color: var(--secondary); }
        .page-header {
            background: linear-gradient(135deg, var(--secondary), #000);
            color: white; padding: 40px 20px; text-align: center;
            border-bottom-left-radius: 40px; border-bottom-right-radius: 40px;
        } 
        .page-header h1 { font-size: 2rem; font-weight: 700; }
        .page-header p  { opacity: 0.7; margin-top: 6px; font-size: 14px; }
        .cart-wrapper { max-width: 800px; margin: 30px auto; padding: 0 20px 60px; }
        .empty-cart { background: white; border-radius: 20px; padding: 60px 20px; text-align: center; box-shadow: 0 5px 20px rgba(0,0,0,0.06); }
        .empty-cart i  { font-size: 4rem; color: #ddd; margin-bottom: 20px; }
        .empty-cart h3 { color: #888; font-size: 1.3rem; }
        .empty-cart a  { display: inline-block; margin-top: 20px; background: var(--primary); color: white; padding: 12px 30px; border-radius: 12px; text-decoration: none; font-weight: 600; }
        .cart-item {
            background: white; border-radius: 16px; padding: 18px 20px; margin-bottom: 14px;
            display: flex; justify-content: space-between; align-items: center; gap: 15px;
            box-shadow: 0 3px 15px rgba(0,0,0,0.06); border: 1px solid #eee; flex-wrap: wrap;
        }
        .item-info h3 { font-size: 1rem; font-weight: 600; margin-bottom: 4px; }
        .item-info p  { color: #888; font-size: 13px; }
        .item-subtotal { color: var(--accent); font-weight: 700; font-size: 1rem; }
        .qty-controls  { display: flex; align-items: center; gap: 10px; }
        .qty-btn {
            width: 32px; height: 32px; border-radius: 50%; border: none;
            background: #f0f2f5; font-size: 18px; font-weight: 700;
            cursor: pointer; transition: 0.2s; display: flex; align-items: center; justify-content: center;
        }
        .qty-btn:hover { background: var(--primary); color: white; }
        .qty-num { font-weight: 700; font-size: 16px; min-width: 24px; text-align: center; }
        .remove-btn { background: #ffe0e0; color: #e74c3c; border: none; border-radius: 10px; padding: 8px 14px; font-size: 13px; font-weight: 600; cursor: pointer; transition: 0.2s; }
        .remove-btn:hover { background: #e74c3c; color: white; }
        .order-summary { background: white; border-radius: 20px; padding: 28px; margin-top: 24px; box-shadow: 0 5px 20px rgba(0,0,0,0.08); }
        .order-summary h2 { font-size: 1.2rem; font-weight: 700; margin-bottom: 20px; }
        .summary-row { display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 14px; color: #666; }
        .summary-row.total { border-top: 2px dashed #eee; padding-top: 14px; margin-top: 14px; font-size: 1.2rem; font-weight: 700; color: var(--secondary); }
        .pickup-label { display: block; font-size: 13px; font-weight: 600; color: #555; margin-bottom: 8px; margin-top: 18px; }
        .pickup-input { width: 100%; padding: 12px 16px; border: 1px solid #e0e0e0; border-radius: 12px; font-size: 14px; font-family: 'Poppins', sans-serif; outline: none; transition: 0.2s; }
        .pickup-input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(255,107,29,0.15); }
        .confirm-btn {
            width: 100%; margin-top: 22px; padding: 15px;
            background: var(--primary); color: white; border: none;
            border-radius: 14px; font-size: 16px; font-weight: 700;
            font-family: 'Poppins', sans-serif; cursor: pointer; transition: 0.3s;
            display: flex; align-items: center; justify-content: center; gap: 10px;
        }
        .confirm-btn:hover { background: #e55a0f; }
        .confirm-btn:disabled { background: #ccc; cursor: not-allowed; }
        .clear-btn {
            width: 100%; margin-top: 12px; padding: 12px;
            background: transparent; color: #e74c3c;
            border: 2px solid #e74c3c; border-radius: 14px;
            font-size: 14px; font-weight: 600; font-family: 'Poppins', sans-serif;
            cursor: pointer; transition: 0.3s;
        }
        .clear-btn:hover { background: #e74c3c; color: white; }
        #toast {
            position: fixed; bottom: 30px; right: 30px;
            background: var(--secondary); color: white;
            padding: 14px 22px; border-radius: 14px; font-size: 14px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.2);
            transform: translateY(100px); opacity: 0; transition: all 0.4s ease; z-index: 9999;
        }
        #toast.show { transform: translateY(0); opacity: 1; }
    </style>
</head>
<body>

<%- include("partials/navbar", { user: user }) %>

<div class="page-header">
    <h1>🛒 Your Cart</h1>
    <p>Review your items before ordering</p>
</div>

<div class="cart-wrapper">
    <div id="cartContainer"></div>

    <div id="summaryBox" class="order-summary" style="display:none;">
        <h2>📋 Order Summary</h2>
        <div id="summaryItems"></div>
        <div class="summary-row total">
            <span>Total Amount</span>
            <span>₹<span id="totalPrice">0</span></span>
        </div>
        <label class="pickup-label">⏰ Pickup Time</label>
        <input type="time" id="pickupTime" class="pickup-input">
        <button class="confirm-btn" id="confirmBtn" onclick="confirmOrder()">
            <i class="fas fa-check-circle"></i> Confirm Order
        </button>
        <button class="clear-btn" onclick="clearCart()">🗑️ Clear Cart</button>
    </div>
</div>

<div id="toast"></div>

<%- include("partials/footer") %>

<script>
const currentUser = <%- JSON.stringify(typeof user !== 'undefined' ? user : null) %>;

function renderCart() {
    const cart = JSON.parse(localStorage.getItem("cart")) || [];
    const container  = document.getElementById("cartContainer");
    const summaryBox = document.getElementById("summaryBox");

    if (cart.length === 0) {
        container.innerHTML = `
            <div class="empty-cart">
                <i class="fas fa-shopping-cart"></i>
                <h3>Your cart is empty!</h3>
                <a href="/products">Browse Menu</a>
            </div>`;
        summaryBox.style.display = "none";
        return;
    }

    let total = 0;
    let cartHTML = "";
    let summaryHTML = "";

    cart.forEach((item, index) => {
        const subtotal = Number(item.price) * Number(item.quantity);
        total += subtotal;

        cartHTML += `
            <div class="cart-item">
                <div class="item-info">
                    <h3>${item.name}</h3>
                    <p>₹${item.price} per item</p>
                </div>
                <div class="qty-controls">
                    <button class="qty-btn" onclick="decreaseQty(${index})">−</button>
                    <span class="qty-num">${item.quantity}</span>
                    <button class="qty-btn" onclick="increaseQty(${index})">+</button>
                </div>
                <span class="item-subtotal">₹${subtotal}</span>
                <button class="remove-btn" onclick="removeItem(${index})">
                    <i class="fas fa-trash"></i> Remove
                </button>
            </div>`;

        summaryHTML += `
            <div class="summary-row">
                <span>${item.name} × ${item.quantity}</span>
                <span>₹${subtotal}</span>
            </div>`;
    });

    container.innerHTML = cartHTML;
    document.getElementById("summaryItems").innerHTML = summaryHTML;
    document.getElementById("totalPrice").innerText = total;
    summaryBox.style.display = "block";
}

function increaseQty(index) {
    let cart = JSON.parse(localStorage.getItem("cart")) || [];
    cart[index].quantity += 1;
    localStorage.setItem("cart", JSON.stringify(cart));
    renderCart(); updateNavCartCount();
}

function decreaseQty(index) {
    let cart = JSON.parse(localStorage.getItem("cart")) || [];
    if (cart[index].quantity > 1) cart[index].quantity -= 1;
    else cart.splice(index, 1);
    localStorage.setItem("cart", JSON.stringify(cart));
    renderCart(); updateNavCartCount();
}

function removeItem(index) {
    let cart = JSON.parse(localStorage.getItem("cart")) || [];
    cart.splice(index, 1);
    localStorage.setItem("cart", JSON.stringify(cart));
    renderCart(); updateNavCartCount();
    showToast("Item removed!");
}

function clearCart() {
    if (!confirm("Cart clear karna chahte ho?")) return;
    localStorage.removeItem("cart");
    renderCart(); updateNavCartCount();
}

async function confirmOrder() {
    if (!currentUser) {
        showToast("Pehle login karein!");
        setTimeout(() => window.location.href = "/login", 1000);
        return;
    }

    const cart = JSON.parse(localStorage.getItem("cart")) || [];
    if (cart.length === 0) { showToast("Cart empty hai!"); return; }

    const pickupTime = document.getElementById("pickupTime").value;
    if (!pickupTime) { showToast("Pickup time select karein!"); return; }

    const btn = document.getElementById("confirmBtn");
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Placing Order...';

    try {
        const res = await fetch("/orders/place", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ items: cart, pickupTime })
        });

        const data = await res.json();

        if (data.success) {
            localStorage.removeItem("cart");
            updateNavCartCount();
            showToast("✅ Order placed successfully!");
            setTimeout(() => window.location.href = "/orders", 1200);
        } else {
            showToast("❌ " + (data.message || "Order failed"));
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-check-circle"></i> Confirm Order';
        }
    } catch (err) {
        showToast("❌ Server error. Try again.");
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-check-circle"></i> Confirm Order';
    }
}

function updateNavCartCount() {
    const el = document.getElementById("cartCount");
    if (!el) return;
    const cart = JSON.parse(localStorage.getItem("cart")) || [];
    el.innerText = cart.reduce((t, i) => t + i.quantity, 0);
}

function showToast(msg) {
    const toast = document.getElementById("toast");
    toast.innerText = msg;
    toast.classList.add("show");
    setTimeout(() => toast.classList.remove("show"), 2500);
}

document.addEventListener("DOMContentLoaded", () => {
    renderCart();
    updateNavCartCount();
    const now = new Date();
    now.setMinutes(now.getMinutes() + 30);
    const hh = String(now.getHours()).padStart(2, '0');
    const mm = String(now.getMinutes()).padStart(2, '0');
    document.getElementById("pickupTime").value = `${hh}:${mm}`;
});
</script>
</body>
</html>
 